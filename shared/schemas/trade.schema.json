{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://tnsvt.io/schemas/trade.json",
  "title": "Trade",
  "description": "Schema para trades ejecutados (evento del event sourcing)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "trade_id",
    "order_id",
    "signal_id",
    "broker",
    "account_id",
    "symbol",
    "side",
    "quantity",
    "entry_price",
    "opened_at"
  ],
  "properties": {
    "trade_id": {
      "type": "string",
      "format": "uuid"
    },
    "order_id": {
      "type": "string",
      "format": "uuid"
    },
    "signal_id": {
      "type": "string",
      "format": "uuid"
    },
    "broker": {
      "type": "string",
      "enum": ["mt5", "ctrader", "binance", "bybit", "ibkr"]
    },
    "account_id": {
      "type": "string"
    },
    "symbol": {
      "type": "string"
    },
    "side": {
      "type": "string",
      "enum": ["buy", "sell"]
    },
    "quantity": {
      "type": "number",
      "minimum": 0.01
    },
    "entry_price": {
      "type": "number",
      "minimum": 0
    },
    "exit_price": {
      "type": ["number", "null"],
      "description": "Precio de cierre (null si está abierto)"
    },
    "stop_loss": {
      "type": ["number", "null"]
    },
    "take_profit": {
      "type": ["number", "null"]
    },
    "commission": {
      "type": "number",
      "default": 0
    },
    "swap": {
      "type": "number",
      "default": 0
    },
    "pnl": {
      "type": "number",
      "description": "Profit & Loss del trade (positivo = ganancia)"
    },
    "pnl_pips": {
      "type": "number",
      "description": "P&L en pips"
    },
    "pnl_percent": {
      "type": "number",
      "description": "P&L como porcentaje del balance"
    },
    "status": {
      "type": "string",
      "enum": ["open", "closed", "partial"],
      "default": "open"
    },
    "close_reason": {
      "type": "string",
      "enum": ["tp", "sl", "manual", "signal", "risk", "news", "margin", "trailing"]
    },
    "opened_at": {
      "type": "integer",
      "format": "int64"
    },
    "closed_at": {
      "type": ["integer", "null"],
      "format": "int64"
    },
    "duration_seconds": {
      "type": "integer",
      "description": "Duración en segundos (0 si está abierto)"
    },
    "magic_number": {
      "type": "integer"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  }
}