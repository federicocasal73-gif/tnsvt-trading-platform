# ═══════════════════════════════════════════════════════════════
# TNSVT V2 - Variables de Entorno (Plantilla)
# ═══════════════════════════════════════════════════════════════
# Copiar a .env y completar con tus valores reales
# cp .env.example .env

# ─── General ────────────────────────────────────────────────────
ENV=development
LOG_LEVEL=info
TZ=UTC
PROJECT_NAME=tnsvt-v2

# ─── PostgreSQL + TimescaleDB ───────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=tnsvt
POSTGRES_USER=tnsvt
POSTGRES_PASSWORD=change_me_in_production_min_16_chars
POSTGRES_MAX_CONNECTIONS=200
POSTGRES_SHARED_BUFFERS=256MB

# ─── Redis ──────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_MAX_CONNECTIONS=50
REDIS_TTL_DEFAULT=3600

# ─── NATS + JetStream ───────────────────────────────────────────
NATS_HOST=localhost
NATS_PORT=4222
NATS_MONITOR_PORT=8222
NATS_CLUSTER_NAME=tnsvt-cluster
NATS_MAX_PAYLOAD=10MB
NATS_JETSTREAM_STORE_DIR=/data/jetstream

# ─── Ollama (LLM self-hosted) ───────────────────────────────────
OLLAMA_HOST=localhost
OLLAMA_PORT=11434
OLLAMA_MODEL=llama3:8b
# Alternativas: mistral:7b, mixtral:8x7b, phi3:medium, codellama:13b

# ─── Traefik (API Gateway) ──────────────────────────────────────
TRAEFIK_DASHBOARD_PORT=8080
TRAEFIK_HTTP_PORT=80
TRAEFIK_HTTPS_PORT=443
TRAEFIK_API_DASHBOARD=true
TRAEFIK_LOG_LEVEL=INFO

# ─── Auth Service ───────────────────────────────────────────────
AUTH_SERVICE_PORT=8001
JWT_SECRET=change_me_min_32_chars_random_string_here_abc123
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_ALGORITHM=HS256
BCRYPT_ROUNDS=12
SESSION_TIMEOUT_HOURS=1
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_SECONDS=60

# ─── User Service ───────────────────────────────────────────────
USER_SERVICE_PORT=8002
DEFAULT_TENANT_SCHEMA=public
TENANT_ISOLATION_MODE=schema_per_tenant

# ─── API Gateway ────────────────────────────────────────────────
API_GATEWAY_PORT=8000
API_GATEWAY_RATE_LIMIT=100
API_GATEWAY_RATE_LIMIT_WINDOW=60

# ─── Signal Engine ──────────────────────────────────────────────
SIGNAL_ENGINE_PORT=8003
TELETHON_API_ID=12345678
TELETHON_API_HASH=your_api_hash_here
TELETHON_PHONE=+1234567890
SIGNAL_DEDUP_TTL_MINUTES=10
SIGNAL_QUEUE_MAX_SIZE=100

# ─── Execution Engine ───────────────────────────────────────────
EXECUTION_ENGINE_PORT=8004
EXECUTION_TIMEOUT_SECONDS=30
EXECUTION_RETRY_MAX=3
EXECUTION_RETRY_BACKOFF=2

# ─── Copy Trading ───────────────────────────────────────────────
COPY_TRADING_PORT=8005
COPY_TRADING_MAX_ACCOUNTS=20

# ─── Risk Engine ────────────────────────────────────────────────
RISK_ENGINE_PORT=8006
RISK_DAILY_LOSS_LIMIT=500.0
RISK_DAILY_PROFIT_TARGET=1000.0
RISK_WEEKLY_LOSS_LIMIT=1500.0
RISK_MAX_OPEN_POSITIONS=5
RISK_TRAILING_STOP=true
RISK_TRAILING_STEP=10

# ─── MT5 Connector ──────────────────────────────────────────────
MT5_CONNECTOR_PORT=8007
MT5_PATH=C:\Program Files\FTMO MetaTrader 5\terminal64.exe
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=FTMO-Demo
MT5_MAGIC_NUMBER=123456
MT5_DEVIATION=20
MT5_SYMBOL_SUFFIX=

# ─── Audit Engine ───────────────────────────────────────────────
AUDIT_ENGINE_PORT=8008
AUDIT_RETENTION_DAYS=365
AUDIT_HASH_ALGORITHM=sha256

# ─── AI Core ────────────────────────────────────────────────────
AI_CORE_PORT=8010
AI_CORE_MODEL=llama3:8b
AI_CORE_SCORE_THRESHOLD=0.65
AI_CORE_REGIME_DETECTION=true
AI_CORE_SENTIMENT_ENABLED=true
AI_CORE_RAG_ENABLED=true

# ─── Regime Detector ────────────────────────────────────────────
REGIME_DETECTOR_PORT=8011
REGIME_DETECTION_INTERVAL_SECONDS=60
MARKET_DATA_WEBSOCKET_URL=

# ─── Price Feed ─────────────────────────────────────────────────
PRICE_FEED_PORT=8012
PRICE_FEED_SYMBOLS=EURUSD,GBPUSD,USDJPY,GBPJPY,XAUUSD
PRICE_FEED_UPDATE_INTERVAL_MS=1000

# ─── Telegram Notifier ──────────────────────────────────────────
TELEGRAM_NOTIFIER_PORT=8013
TELEGRAM_BOT_TOKEN=
TELEGRAM_OWNER_ID=
TELEGRAM_ADMIN_IDS=
TELEGRAM_GROUP_CHAT_ID=
DAILY_SUMMARY_HOUR_UTC=20

# ─── Frontend (Next.js) ─────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws
FRONTEND_PORT=3000

# ─── Observability ──────────────────────────────────────────────
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_ADMIN_PASSWORD=admin
LOKI_URL=http://loki:3100
TEMPO_URL=http://tempo:3200

# ─── Billing / Subscription ─────────────────────────────────────
BILLING_ENABLED=false
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── Secrets Manager ────────────────────────────────────────────
SECRETS_BACKEND=env_file
# Alternativas: vault, aws_secrets_manager, gcp_secret_manager

# ─── Feature Flags ──────────────────────────────────────────────
FEATURE_AI_CORE_ENABLED=true
FEATURE_COPY_TRADING_ENABLED=true
FEATURE_NEWS_FILTER_ENABLED=true
FEATURE_BACKTEST_ENABLED=false
FEATURE_LLM_AGENT_ENABLED=false

# ═══════════════════════════════════════════════════════════════
# FIN
# ═══════════════════════════════════════════════════════════════