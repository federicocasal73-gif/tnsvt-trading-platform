# ============================================
# TERMINAL FINANCIERA PRO - Variables de Entorno
# ============================================
# Copia este archivo a .env y completa tus valores

# Bot de Telegram
BOT_TOKEN=

# Trading Economics
TRADING_USERNAME=
TRADING_PASSWORD=

# JBlanked API
JBLANKED_API_KEY=

# News API
NEWSAPI_KEY=

# Signal Copier - Telethon
TELETHON_API_ID=
TELETHON_API_HASH=
TELETHON_PHONE=

# Canales monitoreados (nombre=habilitado, separados por coma)
CHANNELS=Prueba=true,Prueba 2=true

# MT5
SYMBOL_SUFFIX=
LOT_SIZE=0.01
LOT_MODE=fixed
LOT_RISK_PERCENT=1.0
DEVIATION=20

# Risk Management
RISK_DAILY_LOSS_LIMIT=2.0
RISK_DAILY_PROFIT_TARGET=5.0
RISK_WEEKLY_LOSS_LIMIT=5.0
RISK_MAX_OPEN_POSITIONS=5
RISK_TRAILING_STOP=false
RISK_TRAILING_STEP=10
RISK_TRAILING_START=50

# News Filter
NEWS_FILTER_ENABLED=true
NEWS_FILTER_MINUTES_BEFORE=15
NEWS_FILTER_MINUTES_AFTER=15
NEWS_FILTER_HIGH_IMPACT_ONLY=true

# Dashboard
DASHBOARD_PORT=8501

# ============================================
# TNSVT BRIDGE - Comunicacion con TNSVT Symphony
# ============================================
TNSVT_URL=http://192.168.1.2:8000
TNSVT_USER_CODE=DEMO
TNSVT_ADMIN_PASSWORD=
BRIDGE_PORT=8502
